# Application Domain
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth Environment Variables
# Keep this aligned with the exact local origin you test against.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_your_secret_with_openssl_rand_base64_32

# Google OAuth (For generic google sign in)
# Local callback for smoke tests: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Social Connectors and Background Scan
# Tokens are encrypted at rest. A dedicated key is recommended, but the app
# can fall back to NEXTAUTH_SECRET locally if you leave this blank.
SOCIAL_TOKEN_ENCRYPTION_KEY=generate_your_secret_with_openssl_rand_base64_32
# Optional but recommended for the async worker route. Without this, local chat
# loads can inline-process one queued social scan for the current user.
SOCIAL_SCAN_WORKER_SECRET=generate_your_secret_with_openssl_rand_base64_32

# Meta OAuth (Shared by Facebook + Instagram)
# Local callbacks:
# http://localhost:3000/api/social/facebook/callback
# http://localhost:3000/api/social/instagram/callback
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# X OAuth
# Local callback: http://localhost:3000/api/social/x/callback
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret

# LinkedIn OAuth
# Local callback: http://localhost:3000/api/social/linkedin/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# TikTok OAuth
# Local callback: http://localhost:3000/api/social/tiktok/callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Supabase Databse Configuration (Production)
# DATABASE_URL = Connection Pooled (e.g. pgBouncer port 6543)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL = Direct connection for Prisma Migrations/Seed (Db port 5432)
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# (Optional) Supabase API access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription Price Definitions
# Core and Pro are the recurring continuity plans used by the landing page,
# read-only renewal flow, and webhook-backed subscription sync.
STRIPE_PRICE_ID_MONTHLY_CORE=price_monthly_core_id
STRIPE_PRICE_ID_MONTHLY_PRO=price_monthly_pro_id
# Optional one-time unlocks
STRIPE_PRICE_ID_STELLAR_INSIGHT=price_stellar_insight_id
STRIPE_PRICE_ID_MIDNIGHT_CHANNEL=price_midnight_channel_id
STRIPE_PRICE_ID_VOICE_MEMORY=price_voice_memory_id
STRIPE_PRICE_ID_MEMORY_VAULT=price_memory_vault_id
STRIPE_PRICE_ID_TELEPATHIC_PINGS=price_telepathic_pings_id

# Live Runtime Configuration
# OpenRouter is the provider-backed fallback when the OpenClaw gateway is
# unavailable or still being verified.
OPENROUTER_API_KEY=
# Optional gateway override for local or hosted OpenClaw relay instances.
# Defaults to http://127.0.0.1:18789 when omitted.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# OpenAI Configuration
# Used for real voice-note transcription, optional Angel voice replies, and AI photo memories.
OPENAI_API_KEY=
# Higher-quality transcription model for inbound voice notes.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# Optional Angel text-to-speech model + built-in voice.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=verse

# Live Weather Context (Optional)
# Adds current weather to the bounded session brief when city data is present.
OPENWEATHERMAP_API_KEY=

# (Optional) Admins
# Comma-separated allowlist of emails to receive "SUPERADMIN" role
SUPERADMIN_EMAILS=

# Web Push Configuration (VAPID)
# Used for authenticating push notifications to browser push services.
# Generate new keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BJsdqbFMr9ibFQ6dbHv0-n-Gw8giwn1gemJ71sRcDLzr2bxNuFfUzDfBsKssWFLvvtWPUWu_x2TGGyeNRkJhi5lI
VAPID_PRIVATE_KEY=ipn5q_QM3vo6L6KH5S0TYS9dSPOUbRwV1Jm6bFMAp_c
VAPID_SUBJECT=mailto:support@angel.ai
